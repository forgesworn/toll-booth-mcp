{
  "name": "toll-booth-mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "Admin MCP server with interactive UI widgets for monitoring toll-booth deployments",
  "main": "dist/src/index.js",
  "bin": {
    "toll-booth-mcp": "dist/src/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.server.json && node scripts/build-widgets.mjs",
    "build:server": "tsc -p tsconfig.server.json",
    "build:widgets": "node scripts/build-widgets.mjs",
    "test": "vitest run",
    "start": "node dist/src/index.js",
    "start:http": "TRANSPORT=http node dist/src/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.6.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^24.12.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.3",
    "vitest": "^4.1.5"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "forgesworn"
}
